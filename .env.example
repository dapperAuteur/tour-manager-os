# Supabase (mapped for Next.js client access)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase (Vercel integration provides these)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_SECRET_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Postgres (Vercel integration provides these)
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_PRISMA_URL=
POSTGRES_HOST=
POSTGRES_DATABASE=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Cloudinary
CLOUDINARY_API_KEY=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Mailgun (Email)
MAILGUN_API_KEY=
# HTTP webhook signing key — different from the API key above. Get
# it from Mailgun → Sending → Webhooks → "HTTP webhook signing key"
# (or Mailgun Settings → API Security). Required for /api/webhooks/
# mailgun to accept events; without it, every webhook returns 401.
MAILGUN_WEBHOOK_SIGNING_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=us
EMAIL_FROM="Tour Manager OS <noreply@mg.witus.online>"
ADMIN_NOTIFY_EMAIL=

# AI providers (routed through Vercel AI Gateway via AI SDK v6)
# Defaults to mistral/mistral-embed for embeddings (1024 dims). To
# change models, also update help_articles.embedding dimensions via
# a new migration.
AI_EMBEDDING_MODEL=mistral/mistral-embed
AI_EMBEDDING_DIMS=1024
# Conversational help agent. Cerebras Llama 3.3 70B is the fastest
# streaming option; swap to openrouter/anthropic/claude-3.5-sonnet
# for quality or mistral/mistral-large-latest as a middle ground.
AI_CHAT_MODEL=cerebras/gpt-oss-120b
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=

# LangSmith (LLM observability — wraps embed/chat/vision calls)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=tour-manager-os
LANGSMITH_TRACING=true

# PostHog (Product Analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Stripe Pricing
STRIPE_LIFETIME_PRICE_ID=
STRIPE_ANNUAL_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

CRON_SECRET=

# Ticketing (Phase 24)
# Generate a 32+ byte secret: `openssl rand -base64 48`
TICKET_SIGNING_SECRET=

# WitUS Inbox (mirror in-app help/feedback/bug submissions to BAM's
# central triage queue at inbox.witus.online, which auto-forwards to the
# WitUS Triage agent). The mirror is non-blocking: if these are unset the
# feedback still saves to Supabase — it just won't reach the Inbox.
#   1. BAM generates a per-environment secret: `openssl rand -hex 32`
#   2. BAM registers {"slug":"tour-witus","hmac_secret":"<that>"} in the
#      witus-inbox INGEST_SOURCES env var for the matching environment.
#   3. INBOX_INGEST_SECRET below must byte-match that secret.
# See plans/user-tasks/ for the registration task.
INBOX_INGEST_URL=https://inbox.witus.online/api/ingest
INBOX_SOURCE_SLUG=tour-witus
INBOX_INGEST_SECRET=

# --- WitUS ecosystem: Outbox (outbound social drafts -> BAM accounts) ---
OUTBOX_INGEST_URL=https://outbox.witus.online/api/ingest
OUTBOX_SOURCE_SLUG=tour-witus
OUTBOX_INGEST_SECRET=
OUTBOX_TRIGGER_ENABLED=true
